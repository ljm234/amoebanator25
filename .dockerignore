# Exclude the entire audit dir, not just the file. The dev-machine audit log
# carries dev-side actor strings + filesystem paths that should never ship to
# a public HF Space build. The container starts with an empty audit dir on
# every cold-boot; the genesis entry is emitted on first prediction.
outputs/audit/
outputs/metrics/*.png
outputs/model/__pycache__/
